{"mode":"Text","hardwareTarget":"brain","textContent":"#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain=Brain()\n\n# Robot configuration code\nmotorVision = Motor(Ports.PORT3, GearSetting.RATIO_18_1, False)\nopLeft = Optical(Ports.PORT5)\nopRight = Optical(Ports.PORT6)\ndistanceLeft = Distance(Ports.PORT4)\ndistanceRight = Distance(Ports.PORT8)\nopticalDown = Optical(Ports.PORT7)\nback_right = Motor(Ports.PORT16, GearSetting.RATIO_18_1, False)\nfront_right = Motor(Ports.PORT17, GearSetting.RATIO_18_1, False)\nfront_left = Motor(Ports.PORT14, GearSetting.RATIO_18_1, True)\nback_left = Motor(Ports.PORT15, GearSetting.RATIO_18_1, True)\ncontroller_1 = Controller(PRIMARY)\n\n# wait for rotation sensor to fully initialize\nwait(30, MSEC)\n\ndef initializeRandomSeed():\n    wait(100, MSEC)\n    random = brain.battery.voltage(MV) + brain.battery.current(CurrentUnits.AMP) * 100 + brain.timer.system_high_res()\n    urandom.seed(int(random))\n      \ninitializeRandomSeed()\n\ndef play_vexcode_sound(sound_name):\n    print(\"VEXPlaySound:\" + sound_name)\n    wait(5, MSEC)\n\nwait(200, MSEC)\nprint(\"\\033[2J\")\n#endregion VEXcode Generated Robot Configuration\n\n\n# ------------------------------------------\n#   Project:      O.A.S.I.S. Master Demo Code\n# ------------------------------------------\n\n# --- GLOBAL TRACKING VARIABLES ---\nroom_map = [[0 for x in range(37)] for y in range(33)]\nrobot_x_inches = 18.0 * 12.0\nrobot_y_inches = 15.0 * 12.0\nradar_active = False # Safe toggle for radar\n\n\n# --- 0. DRIVE HOLONOMIC (Moved to top so other functions can see it!) ---\ndef drive_holonomic(vy, vx, vtheta):\n    fl_speed = vy + vx + vtheta\n    fr_speed = vy - vx - vtheta\n    bl_speed = vy - vx + vtheta\n    br_speed = vy + vx - vtheta\n    front_left.spin(FORWARD, fl_speed, PERCENT)\n    front_right.spin(FORWARD, fr_speed, PERCENT)\n    back_left.spin(FORWARD, bl_speed, PERCENT)\n    back_right.spin(FORWARD, br_speed, PERCENT)\n\n\n# --- 1. ODOMETRY BACKGROUND THREAD ---\ndef odometry_task():\n    global robot_x_inches, robot_y_inches\n    pi = 3.14159\n    wheel_circumference = 4.0 * pi \n    \n    prev_fl = 0; prev_fr = 0; prev_bl = 0; prev_br = 0\n    \n    front_left.set_position(0, TURNS)\n    front_right.set_position(0, TURNS)\n    back_left.set_position(0, TURNS)\n    back_right.set_position(0, TURNS)\n    \n    THRESHOLD = 50 # Make sure this matches your calibration!\n    line_crossed = False\n    \n    while True:\n        fl_revs = front_left.position(TURNS)\n        fr_revs = front_right.position(TURNS)\n        bl_revs = back_left.position(TURNS)\n        br_revs = back_right.position(TURNS)\n        \n        d_fl = fl_revs - prev_fl\n        d_fr = fr_revs - prev_fr\n        d_bl = bl_revs - prev_bl\n        d_br = br_revs - prev_br\n        \n        prev_fl = fl_revs; prev_fr = fr_revs; prev_bl = bl_revs; prev_br = br_revs\n        \n        # INVERTED MATH TO MATCH YOUR JOYSTICKS\n        dy_revs = -((d_fl + d_fr + d_bl + d_br) / 4.0)\n        dx_revs = -((d_fl - d_fr - d_bl + d_br) / 4.0)\n        \n        robot_y_inches += dy_revs * wheel_circumference\n        robot_x_inches += dx_revs * wheel_circumference\n        \n        # Grid Snapping\n        current_brightness = opticalDown.brightness()\n        if current_brightness < THRESHOLD and not line_crossed:\n            robot_y_inches = round(robot_y_inches / 12.0) * 12.0\n            robot_x_inches = round(robot_x_inches / 12.0) * 12.0\n            line_crossed = True\n        elif current_brightness > (THRESHOLD + 10):\n            line_crossed = False\n            \n        wait(20, MSEC)\n\n\n# --- 2. VECTOR FIELD NAVIGATION (AUTONOMOUS) ---\ndef navigate_to_target(target_y_tiles, target_x_tiles):\n    target_y_in = target_y_tiles * 12.0\n    target_x_in = target_x_tiles * 12.0\n    \n    # LOWERED SPEED to stop the back-and-forth overshoot\n    Kp_attractive = 1.5   \n    # MUTED for safety so it doesn't phantom dodge\n    Kp_repulsive = 0.0 \n    \n    while True:\n        err_y = target_y_in - robot_y_inches\n        err_x = target_x_in - robot_x_inches\n        distance_to_target = math.sqrt(err_y**2 + err_x**2)\n        \n        # WIDENED TARGET ZONE to 3 inches to prevent micro-adjusting\n        if distance_to_target < 3.0:\n            drive_holonomic(0, 0, 0)\n            brain.screen.print(\"Arrived at Waypoint!\")\n            break\n            \n        attr_y = err_y * Kp_attractive\n        attr_x = err_x * Kp_attractive\n        \n        final_vy = attr_y \n        final_vx = attr_x \n        \n        # Max speed caps\n        if final_vy > 70: final_vy = 70\n        if final_vy < -70: final_vy = -70\n        if final_vx > 70: final_vx = 70\n        if final_vx < -70: final_vx = -70\n        \n        # Output with inverted signs to match your hardware\n        drive_holonomic(-final_vy, -final_vx, 0)\n        wait(20, MSEC)\n\n\n# --- 3. RADAR SWEEP THREAD ---\ndef radar_sweep_task():\n    global radar_active\n    #","textLanguage":"python","robotConfig":[{"port":[3],"name":"motorVision","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[5],"name":"opLeft","customName":true,"deviceType":"Optical","deviceClass":"optical","setting":{},"triportSourcePort":22},{"port":[6],"name":"opRight","customName":true,"deviceType":"Optical","deviceClass":"optical","setting":{},"triportSourcePort":22},{"port":[4],"name":"distanceLeft","customName":true,"deviceType":"Distance","deviceClass":"distance","setting":{},"triportSourcePort":22},{"port":[7],"name":"opticalDown","customName":true,"deviceType":"Optical","deviceClass":"optical","setting":{},"triportSourcePort":22},{"port":[16],"name":"back_right","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[17],"name":"front_right","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[14],"name":"front_left","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"true","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[15],"name":"back_left","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"true","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[],"name":"controller_1","customName":false,"deviceType":"Controller","deviceClass":"controller","setting":{"left":"","leftDir":"false","right":"","rightDir":"false","upDown":"","upDownDir":"false","xB":"","xBDir":"false","drive":"none","id":"primary"},"triportSourcePort":22}],"slot":0,"platform":"V5","sdkVersion":"20240802.15.00.00","appVersion":"4.65.0","fileFormat":"2.0.0","targetBrainGen":"First","v5Sounds":[{"name":"game over","url":"static/sounds/mixkit-arcade-retro-game-over-213.wav"}],"v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null}}