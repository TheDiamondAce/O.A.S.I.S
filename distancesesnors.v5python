{"mode":"Text","hardwareTarget":"brain","textContent":"#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain=Brain()\n\n# Robot configuration code\nmotorVision = Motor(Ports.PORT3, GearSetting.RATIO_18_1, False)\nopLeft = Optical(Ports.PORT5)\nopRight = Optical(Ports.PORT6)\ndistanceLeft = Distance(Ports.PORT4)\nopticalRight = Optical(Ports.PORT7)\nfront_right = Motor(Ports.PORT16, GearSetting.RATIO_18_1, False)\nback_right = Motor(Ports.PORT17, GearSetting.RATIO_18_1, False)\nback_left = Motor(Ports.PORT14, GearSetting.RATIO_18_1, False)\nfront_left = Motor(Ports.PORT15, GearSetting.RATIO_18_1, False)\n\n\n# wait for rotation sensor to fully initialize\nwait(30, MSEC)\n\n\n# Make random actually random\ndef initializeRandomSeed():\n    wait(100, MSEC)\n    random = brain.battery.voltage(MV) + brain.battery.current(CurrentUnits.AMP) * 100 + brain.timer.system_high_res()\n    urandom.seed(int(random))\n      \n# Set random seed \ninitializeRandomSeed()\n\n\n# Color to String Helper\ndef convert_color_to_string(col):\n    if col == Color.RED:\n        return \"red\"\n    if col == Color.GREEN:\n        return \"green\"\n    if col == Color.BLUE:\n        return \"blue\"\n    if col == Color.WHITE:\n        return \"white\"\n    if col == Color.YELLOW:\n        return \"yellow\"\n    if col == Color.ORANGE:\n        return \"orange\"\n    if col == Color.PURPLE:\n        return \"purple\"\n    if col == Color.CYAN:\n        return \"cyan\"\n    if col == Color.BLACK:\n        return \"black\"\n    if col == Color.TRANSPARENT:\n        return \"transparent\"\n    return \"\"\n\ndef play_vexcode_sound(sound_name):\n    # Helper to make playing sounds from the V5 in VEXcode easier and\n    # keeps the code cleaner by making it clear what is happening.\n    print(\"VEXPlaySound:\" + sound_name)\n    wait(5, MSEC)\n\n# add a small delay to make sure we don't print in the middle of the REPL header\nwait(200, MSEC)\n# clear the console to make sure we don't have the REPL in the console\nprint(\"\\033[2J\")\n\n#endregion VEXcode Generated Robot Configuration\n\n# ------------------------------------------\n# \n# \tProject:      VEXcode Project\n#\tAuthor:       VEX\n#\tCreated:\n#\tDescription:  VEXcode V5 Python Project\n# \n# ------------------------------------------\n\n# Library imports\nfrom vex import *\nstart = False\nmotorVision.set_position(0,DEGREES)\nwait(2,SECONDS)\nstart=True\nmotorVision.set_velocity(25,PERCENT)\nmotorVision.spin(FORWARD)\n\n\n# --- Motor & Kinematics Configuration ---\n# You may need to reverse the right-side motors in your device setup\n# so that positive voltage moves all wheels forward.\n\ndef drive_holonomic(vy, vx, vtheta):\n    # vy: Forward/Backward speed (-100 to 100)\n    # vx: Strafing speed (-100 to 100)\n    # vtheta: Rotation speed (-100 to 100)\n    \n    # Kinematics equations for Mecanum / X-Drive\n    fl_speed = vy + vx + vtheta\n    fr_speed = vy - vx - vtheta\n    bl_speed = vy - vx + vtheta\n    br_speed = vy + vx - vtheta\n    \n    # Spin motors at calculated percentages\n    front_left.spin(FORWARD, fl_speed, PERCENT)\n    front_right.spin(FORWARD, fr_speed, PERCENT)\n    back_left.spin(FORWARD, bl_speed, PERCENT)\n    back_right.spin(FORWARD, br_speed, PERCENT)\n\n\n# --- Main Day 1 Loop ---\ndef main():\n    while True:\n        # Get joystick inputs from Controller 1\n        # Axis 3: Left joystick Up/Down (Forward/Reverse)\n        forward_axis = controller_1.axis3.position()\n        \n        # Axis 4: Left joystick Left/Right (Strafe)\n        strafe_axis = controller_1.axis4.position()\n        \n        # Axis 1: Right joystick Left/Right (Rotate)\n        turn_axis = controller_1.axis1.position()\n        \n        # Create a small deadband so it doesn't drift when joysticks are centered\n        if abs(forward_axis) < 5: forward_axis = 0\n        if abs(strafe_axis) < 5: strafe_axis = 0\n        if abs(turn_axis) < 5: turn_axis = 0\n        \n        # Feed the inputs to the wheels\n        drive_holonomic(forward_axis, strafe_axis, turn_axis)\n        \n        # Very short sleep to prevent the brain from locking up\n        wait(20, MSEC)\n\n# Run the main function\nmain()\n\ndef clearScreen():\n    wait(0.1,SECONDS)\n    brain.screen.clear_screen()\npass\n\ndef checking():\n    brain.screen.set_cursor(1,1)\n    brain.screen.print(\"Rotation Angle: \" + str(motorVision.position(DEGREES)))\n    brain.screen.next_row()\n    brain.screen.print(\"Distance Left: \" + str(distanceLeft.object_distance(INCHES)))\n    brain.screen.next_row()\n    brain.screen.print(\"Distance Right: \" + str(opticalRight.is_near_object()))\n    #The Code for left and right checking\n    if motorVision.position(DEGREES) >= 90:\n        motorVision.spin(REVERSE)\n    pass\n    if motorVision.position(DEGREES) <= -90:\n        motorVision.spin(FORWARD)\n    pass\n\n\npass \n\nwhile start == True:\n    try:\n        clearScreen()\n        checking()\n    except: \n        if motorVision.position(DEGREES) >= 150 or motorVision.position(DEGREES) <= -150:\n            start = False\n            motorVision.stop()\n        pass\n    pass\npass\n# Begin project code\n","textLanguage":"python","robotConfig":[{"port":[3],"name":"motorVision","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[5],"name":"opLeft","customName":true,"deviceType":"Optical","deviceClass":"optical","setting":{},"triportSourcePort":22},{"port":[6],"name":"opRight","customName":true,"deviceType":"Optical","deviceClass":"optical","setting":{},"triportSourcePort":22},{"port":[4],"name":"distanceLeft","customName":true,"deviceType":"Distance","deviceClass":"distance","setting":{},"triportSourcePort":22},{"port":[7],"name":"opticalRight","customName":true,"deviceType":"Optical","deviceClass":"optical","setting":{},"triportSourcePort":22},{"port":[16],"name":"front_right","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio18_1"}},{"port":[17],"name":"back_right","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio18_1"}},{"port":[14],"name":"back_left","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio18_1"}},{"port":[15],"name":"front_left","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio18_1"}}],"slot":0,"platform":"V5","sdkVersion":"20240802.15.00.00","appVersion":"4.65.0","fileFormat":"2.0.0","targetBrainGen":"First","v5Sounds":[{"name":"game over","url":"static/sounds/mixkit-arcade-retro-game-over-213.wav"}],"v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null}}