{"mode":"Text","hardwareTarget":"brain","textContent":"#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain=Brain()\n\n# Robot configuration code\nmotorVision = Motor(Ports.PORT3, GearSetting.RATIO_18_1, False)\nopLeft = Optical(Ports.PORT5)\nopRight = Optical(Ports.PORT6)\ndistanceLeft = Distance(Ports.PORT4)\nopticalDown = Optical(Ports.PORT7)\nback_right = Motor(Ports.PORT16, GearSetting.RATIO_18_1, False)\nfront_right = Motor(Ports.PORT17, GearSetting.RATIO_18_1, False)\nfront_left = Motor(Ports.PORT14, GearSetting.RATIO_18_1, True)\nback_left = Motor(Ports.PORT15, GearSetting.RATIO_18_1, True)\ncontroller_1 = Controller(PRIMARY)\n\n\n# wait for rotation sensor to fully initialize\nwait(30, MSEC)\n\n\n# Make random actually random\ndef initializeRandomSeed():\n    wait(100, MSEC)\n    random = brain.battery.voltage(MV) + brain.battery.current(CurrentUnits.AMP) * 100 + brain.timer.system_high_res()\n    urandom.seed(int(random))\n      \n# Set random seed \ninitializeRandomSeed()\n\n\n# Color to String Helper\ndef convert_color_to_string(col):\n    if col == Color.RED:\n        return \"red\"\n    if col == Color.GREEN:\n        return \"green\"\n    if col == Color.BLUE:\n        return \"blue\"\n    if col == Color.WHITE:\n        return \"white\"\n    if col == Color.YELLOW:\n        return \"yellow\"\n    if col == Color.ORANGE:\n        return \"orange\"\n    if col == Color.PURPLE:\n        return \"purple\"\n    if col == Color.CYAN:\n        return \"cyan\"\n    if col == Color.BLACK:\n        return \"black\"\n    if col == Color.TRANSPARENT:\n        return \"transparent\"\n    return \"\"\n\ndef play_vexcode_sound(sound_name):\n    # Helper to make playing sounds from the V5 in VEXcode easier and\n    # keeps the code cleaner by making it clear what is happening.\n    print(\"VEXPlaySound:\" + sound_name)\n    wait(5, MSEC)\n\n# add a small delay to make sure we don't print in the middle of the REPL header\nwait(200, MSEC)\n# clear the console to make sure we don't have the REPL in the console\nprint(\"\\033[2J\")\n\n#endregion VEXcode Generated Robot Configuration\n#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain=Brain()\n\n# Robot configuration code\nmotorVision = Motor(Ports.PORT3, GearSetting.RATIO_18_1, False)\nopLeft = Optical(Ports.PORT5)\nopRight = Optical(Ports.PORT6)\ndistanceLeft = Distance(Ports.PORT4)\ndistanceRight = Distance(Ports.PORT8)\nopticalDown = Optical(Ports.PORT7)\nback_right = Motor(Ports.PORT16, GearSetting.RATIO_18_1, False)\nfront_right = Motor(Ports.PORT17, GearSetting.RATIO_18_1, False)\nfront_left = Motor(Ports.PORT14, GearSetting.RATIO_18_1, True)\nback_left = Motor(Ports.PORT15, GearSetting.RATIO_18_1, True)\ncontroller_1 = Controller(PRIMARY)\n\n#endregion\n\n# ------------------------------------------\n#   Project:      O.A.S.I.S. Day 3: Vector Fields & Grid Snapping\n# ------------------------------------------\n\n# ------------------------------------------\n#   Project:      O.A.S.I.S. Master Demo Code\n# ------------------------------------------\n\n#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain=Brain()\n\n# Robot configuration code\nmotorVision = Motor(Ports.PORT3, GearSetting.RATIO_18_1, False)\nopLeft = Optical(Ports.PORT5)\nopRight = Optical(Ports.PORT6)\ndistanceLeft = Distance(Ports.PORT4)\ndistanceRight = Distance(Ports.PORT8)\nopticalDown = Optical(Ports.PORT7)\nback_right = Motor(Ports.PORT16, GearSetting.RATIO_18_1, False)\nfront_right = Motor(Ports.PORT17, GearSetting.RATIO_18_1, False)\nfront_left = Motor(Ports.PORT14, GearSetting.RATIO_18_1, True)\nback_left = Motor(Ports.PORT15, GearSetting.RATIO_18_1, True)\ncontroller_1 = Controller(PRIMARY)\n\nwait(30, MSEC)\n\n\nprint(\"\\033[2J\")\n#endregion VEXcode Generated Robot Configuration\n\n\n# ------------------------------------------\n#   Project:      O.A.S.I.S. Master Demo Code\n# ------------------------------------------\n\nroom_map = [[0 for x in range(37)] for y in range(33)]\nrobot_x_inches = 18.0 * 12.0\nrobot_y_inches = 15.0 * 12.0\nradar_active = False \n\n# --- 0. DRIVE HOLONOMIC ---\ndef drive_holonomic(vy, vx, vtheta):\n    fl_speed = vy + vx + vtheta\n    fr_speed = vy - vx - vtheta\n    bl_speed = vy - vx + vtheta\n    br_speed = vy + vx - vtheta\n    front_left.spin(FORWARD, fl_speed, PERCENT)\n    front_right.spin(FORWARD, fr_speed, PERCENT)\n    back_left.spin(FORWARD, bl_speed, PERCENT)\n    back_right.spin(FORWARD, br_speed, PERCENT)\n\n# --- 1. ODOMETRY BACKGROUND THREAD (PURE WHEEL MATH) ---\ndef odometry_task():\n    global robot_x_inches, robot_y_inches\n    pi = 3.14159\n    wheel_circumference = 4.0 * pi \n    \n    prev_fl = 0; prev_fr = 0; prev_bl = 0; prev_br = 0\n    \n    front_left.set_position(0, TURNS)\n    front_right.set_position(0, TURNS)\n    back_left.set_position(0, TURNS)\n    back_right.set_position(0, TURNS)\n    \n    while True:\n        fl_revs = front_left.position(TURNS)\n        fr_revs = front_right.position(TURNS)\n        bl_revs = back_left.position(TURNS)\n        br_revs = back_right.position(TURNS)\n        \n        d_fl = fl_revs - prev_fl\n        d_fr = fr_revs - prev_fr\n        d_bl = bl_revs - prev_bl\n        d_br = br_revs - prev_br\n        \n        prev_fl = fl_revs; prev_fr = fr_revs; prev_bl = bl_revs; prev_br = br_revs\n        \n        dy_revs = -((d_fl + d_fr + d_bl + d_br) / 4.0)\n        dx_revs = -((d_fl - d_fr - d_bl + d_br) / 4.0)\n        \n        # Update global position based ONLY on wheels\n        robot_y_inches += dy_revs * wheel_circumference\n        robot_x_inches += dx_revs * wheel_circumference\n            \n        wait(20, MSEC)\n\n# --- 2. VECTOR FIELD NAVIGATION (DODGING TURNED ON) ---\ndef navigate_to_target(target_y_tiles, target_x_tiles):\n    target_y_in = target_y_tiles * 12.0\n    target_x_in = target_x_tiles * 12.0\n    \n    Kp_attractive = 1.5   \n    Kp_repulsive = 3000.0 \n    \n    while True:\n        err_y = target_y_in - robot_y_inches\n        err_x = target_x_in - robot_x_inches\n        distance_to_target = math.sqrt(err_y**2 + err_x**2)\n        \n        if distance_to_target < 3.0:\n            drive_holonomic(0, 0, 0)\n            break\n            \n        attr_y = err_y * Kp_attractive\n        attr_x = err_x * Kp_attractive\n        \n        repel_y = 0\n        repel_x = 0\n        curr_grid_x = int(robot_x_inches / 12)\n        curr_grid_y = int(robot_y_inches / 12)\n        \n        # Scan for map obstacles and push away from them\n        for gy in range(max(0, curr_grid_y - 2), min(33, curr_grid_y + 2)):\n            for gx in range(max(0, curr_grid_x - 2), min(37, curr_grid_x + 2)):\n                if room_map[gy][gx] == 1: \n                    obs_y_in = (gy * 12) + 6 \n                    obs_x_in = (gx * 12) + 6\n                    \n                    dist_y = robot_y_inches - obs_y_in\n                    dist_x = robot_x_inches - obs_x_in\n                    dist_sq = (dist_y**2 + dist_x**2)\n                    if dist_sq < 1: dist_sq = 1 \n                    \n                    repel_y += (dist_y / dist_sq) * Kp_repulsive\n                    repel_x += (dist_x / dist_sq) * Kp_repulsive\n                    \n        final_vy = attr_y + repel_y\n        final_vx = attr_x + repel_x\n        \n        if final_vy > 70: final_vy = 70\n        if final_vy < -70: final_vy = -70\n        if final_vx > 70: final_vx = 70\n        if final_vx < -70: final_vx = -70\n        \n        drive_holonomic(-final_vy, -final_vx, 0)\n        wait(20, MSEC)\n\n# --- 3. RADAR SWEEP THREAD ---\ndef radar_sweep_task():\n    global radar_active\n    motorVision.set_velocity(15, PERCENT)\n    sweeping_right = True\n    \n    while True:\n        if radar_active:\n            current_angle = motorVision.position(DEGREES)\n            if current_angle >= 90: sweeping_right = False\n            elif current_angle <= -90: sweeping_right = True\n                \n            if sweeping_right: motorVision.spin(FORWARD)\n            else: motorVision.spin(REVERSE)\n                \n            dist = distanceLeft.object_distance(INCHES)\n            if dist > 0 and dist < 48:\n                angle_rad = math.radians(current_angle)\n                obj_x_inches = robot_x_inches + (dist * math.sin(angle_rad))\n                obj_y_inches = robot_y_inches + (dist * math.cos(angle_rad))\n                grid_x = int(obj_x_inches / 12)\n                grid_y = int(obj_y_inches / 12)\n                \n                if 0 <= grid_x < 37 and 0 <= grid_y < 33:\n                    room_map[grid_y][grid_x] = 1 \n        else:\n            motorVision.stop(HOLD)\n            \n        wait(20, MSEC)\n\n# --- 4. DYNAMIC UI THREAD (OPTIMIZED FOR SPEED) ---\ndef ui_task():\n    while True:\n        brain.screen.clear_screen()\n        robot_grid_x = int(robot_x_inches / 12.0)\n        robot_grid_y = int(robot_y_inches / 12.0)\n        \n        offset_x = robot_grid_x - 10\n        offset_y = robot_grid_y - 5\n        \n        for y in range(10):\n            for x in range(20):\n                map_y = offset_y + y\n                map_x = offset_x + x\n                \n                if 0 <= map_x < 37 and 0 <= map_y < 33:\n                    if room_map[map_y][map_x] == 1:\n                        screen_x = x * 24\n                        screen_y = y * 24\n                        brain.screen.set_pen_color(Color.RED)\n                        brain.screen.set_fill_color(Color.RED)\n                        brain.screen.draw_rectangle(screen_x, screen_y, 24, 24)\n                        \n        screen_robot_x = (robot_x_inches / 12.0 - offset_x) * 24.0\n        screen_robot_y = (robot_y_inches / 12.0 - offset_y) * 24.0\n        brain.screen.set_pen_color(Color.GREEN)\n        brain.screen.set_fill_color(Color.GREEN)\n        brain.screen.draw_circle(int(screen_robot_x), int(screen_robot_y), 8)\n        \n        wait(50, MSEC)\n\n# --- MAIN LOOP ---\ndef main():\n    global radar_active\n    \n    # We left this on purely for the visual aesthetic during your presentation\n    opticalDown.set_light(LedStateType.ON)\n    opticalDown.set_light_power(100, PERCENT)\n    motorVision.set_position(0, DEGREES)\n    \n    Thread(radar_sweep_task)\n    Thread(odometry_task)\n    Thread(ui_task)\n    \n    while True:\n        forward_axis = -controller_1.axis3.position()\n        strafe_axis = -controller_1.axis4.position()\n        turn_axis = -controller_1.axis1.position()\n        \n        if abs(forward_axis) < 5: forward_axis = 0\n        if abs(strafe_axis) < 5: strafe_axis = 0\n        if abs(turn_axis) < 5: turn_axis = 0\n        \n        if forward_axis != 0 or strafe_axis != 0 or turn_axis != 0:\n            drive_holonomic(forward_axis, strafe_axis, turn_axis)\n        else:\n            drive_holonomic(0, 0, 0)\n        \n        if controller_1.buttonY.pressing():\n            radar_active = not radar_active\n            wait(250, MSEC) \n            \n        if controller_1.buttonB.pressing():\n            navigate_to_target(18, 18) \n            \n        wait(20, MSEC)\n\nmain()","textLanguage":"python","robotConfig":[{"port":[3],"name":"motorVision","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[5],"name":"opLeft","customName":true,"deviceType":"Optical","deviceClass":"optical","setting":{},"triportSourcePort":22},{"port":[6],"name":"opRight","customName":true,"deviceType":"Optical","deviceClass":"optical","setting":{},"triportSourcePort":22},{"port":[4],"name":"distanceLeft","customName":true,"deviceType":"Distance","deviceClass":"distance","setting":{},"triportSourcePort":22},{"port":[7],"name":"opticalDown","customName":true,"deviceType":"Optical","deviceClass":"optical","setting":{},"triportSourcePort":22},{"port":[16],"name":"back_right","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[17],"name":"front_right","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[14],"name":"front_left","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"true","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[15],"name":"back_left","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"true","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[],"name":"controller_1","customName":false,"deviceType":"Controller","deviceClass":"controller","setting":{"left":"","leftDir":"false","right":"","rightDir":"false","upDown":"","upDownDir":"false","xB":"","xBDir":"false","drive":"none","id":"primary"},"triportSourcePort":22}],"slot":0,"platform":"V5","sdkVersion":"20240802.15.00.00","appVersion":"4.65.0","fileFormat":"2.0.0","targetBrainGen":"First","v5Sounds":[{"name":"game over","url":"static/sounds/mixkit-arcade-retro-game-over-213.wav"}],"v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null}}