{"mode":"Text","hardwareTarget":"brain","textContent":"#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain=Brain()\n\n# Robot configuration code\nmotorVision = Motor(Ports.PORT3, GearSetting.RATIO_18_1, False)\nopLeft = Optical(Ports.PORT5)\nopRight = Optical(Ports.PORT6)\ndistanceLeft = Distance(Ports.PORT4)\nopticalDown = Optical(Ports.PORT7)\nback_right = Motor(Ports.PORT16, GearSetting.RATIO_18_1, False)\nfront_right = Motor(Ports.PORT17, GearSetting.RATIO_18_1, False)\nfront_left = Motor(Ports.PORT14, GearSetting.RATIO_18_1, True)\nback_left = Motor(Ports.PORT15, GearSetting.RATIO_18_1, True)\ncontroller_1 = Controller(PRIMARY)\n\n\n# wait for rotation sensor to fully initialize\nwait(30, MSEC)\n\n\n# Make random actually random\ndef initializeRandomSeed():\n    wait(100, MSEC)\n    random = brain.battery.voltage(MV) + brain.battery.current(CurrentUnits.AMP) * 100 + brain.timer.system_high_res()\n    urandom.seed(int(random))\n      \n# Set random seed \ninitializeRandomSeed()\n\n\n# Color to String Helper\ndef convert_color_to_string(col):\n    if col == Color.RED:\n        return \"red\"\n    if col == Color.GREEN:\n        return \"green\"\n    if col == Color.BLUE:\n        return \"blue\"\n    if col == Color.WHITE:\n        return \"white\"\n    if col == Color.YELLOW:\n        return \"yellow\"\n    if col == Color.ORANGE:\n        return \"orange\"\n    if col == Color.PURPLE:\n        return \"purple\"\n    if col == Color.CYAN:\n        return \"cyan\"\n    if col == Color.BLACK:\n        return \"black\"\n    if col == Color.TRANSPARENT:\n        return \"transparent\"\n    return \"\"\n\ndef play_vexcode_sound(sound_name):\n    # Helper to make playing sounds from the V5 in VEXcode easier and\n    # keeps the code cleaner by making it clear what is happening.\n    print(\"VEXPlaySound:\" + sound_name)\n    wait(5, MSEC)\n\n# add a small delay to make sure we don't print in the middle of the REPL header\nwait(200, MSEC)\n# clear the console to make sure we don't have the REPL in the console\nprint(\"\\033[2J\")\n\n#endregion VEXcode Generated Robot Configuration\n#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain=Brain()\n\n# Robot configuration code\nmotorVision = Motor(Ports.PORT3, GearSetting.RATIO_18_1, False)\nopLeft = Optical(Ports.PORT5)\nopRight = Optical(Ports.PORT6)\ndistanceLeft = Distance(Ports.PORT4)\nopticalDown = Optical(Ports.PORT7)\nback_right = Motor(Ports.PORT16, GearSetting.RATIO_18_1, False)\nfront_right = Motor(Ports.PORT17, GearSetting.RATIO_18_1, False)\nfront_left = Motor(Ports.PORT14, GearSetting.RATIO_18_1, True)\nback_left = Motor(Ports.PORT15, GearSetting.RATIO_18_1, True)\ncontroller_1 = Controller(PRIMARY)\n#endregion\n\n\n# ------------------------------------------\n#   Project:      O.A.S.I.S. Day 2: Radar & Mapping\n# ------------------------------------------\n\n# --- DAY 2: MEMORY MAP & TRACKING VARIABLES ---\n# 33 Rows (Y) by 37 Columns (X) filled with 0s\nroom_map = [[0 for x in range(37)] for y in range(33)]\n\n# Temporary dummy variables for odometry (we will calculate these automatically in Day 3)\nrobot_x_inches = 180.0  # Starting 15 tiles in (15 * 12)\nrobot_y_inches = 180.0  # Starting 15 tiles in (15 * 12)\n\n\n# --- DAY 2: RADAR SWEEP THREAD ---\ndef radar_sweep_task():\n    motorVision.set_velocity(35, PERCENT)\n    sweeping_right = True\n    \n    while True:\n        # 1. Sweep the motor between 90 and -90 degrees\n        current_angle = motorVision.position(DEGREES)\n        \n        if current_angle >= 90:\n            sweeping_right = False\n        elif current_angle <= -90:\n            sweeping_right = True\n            \n        if sweeping_right:\n            motorVision.spin(FORWARD)\n        else:\n            motorVision.spin(REVERSE)\n            \n        # 2. Fire the laser and get distance\n        dist = distanceLeft.object_distance(INCHES)\n        \n        # 3. If an object is detected within 48 inches (4 feet)\n        if dist > 0 and dist < 48:\n            # Convert degrees to radians for math functions\n            angle_rad = math.radians(current_angle)\n            \n            # Polar to Cartesian conversion\n            # (Assuming 0 degrees is facing straight forward down the Y axis)\n            obj_x_inches = robot_x_inches + (dist * math.sin(angle_rad))\n            obj_y_inches = robot_y_inches + (dist * math.cos(angle_rad))\n            \n            # Convert inches to grid tiles\n            grid_x = int(obj_x_inches / 12)\n            grid_y = int(obj_y_inches / 12)\n            \n            # Safety check: Make sure the object is actually inside our 37x33 map\n            if 0 <= grid_x < 37 and 0 <= grid_y < 33:\n                room_map[grid_y][grid_x] = 1 # Mark the obstacle!\n                \n        # Run loop every 20ms to prevent brain lockup\n        wait(20, MSEC)\n\n\n# --- Day 1 Holonomic Drive Function ---\ndef drive_holonomic(vy, vx, vtheta):\n    fl_speed = vy + vx + vtheta\n    fr_speed = vy - vx - vtheta\n    bl_speed = vy - vx + vtheta\n    br_speed = vy + vx - vtheta\n    \n    front_left.spin(FORWARD, fl_speed, PERCENT)\n    front_right.spin(FORWARD, fr_speed, PERCENT)\n    back_left.spin(FORWARD, bl_speed, PERCENT)\n    back_right.spin(FORWARD, br_speed, PERCENT)\n\n# --- Day 1 Sensor Calibration Function ---\ndef calibrate_sensors():\n    brain.screen.clear_screen()\n    opticalDown.set_light(LedStateType.ON)\n    opticalDown.set_light_power(100, PERCENT)\n    \n    while True:\n        floor_brightness = opticalDown.brightness()\n        brain.screen.set_cursor(1, 1)\n        brain.screen.print(\"Floor Brightness: \" + str(floor_brightness) + \"%   \")\n        wait(50, MSEC)\n\n\n# --- Main Loop ---\ndef main():\n    brain.screen.clear_screen()\n    brain.screen.print(\"O.A.S.I.S. Systems Online\")\n    \n    # Reset radar motor to start at exactly 0\n    motorVision.set_position(0, DEGREES)\n    \n    # LAUNCH THE DAY 2 RADAR IN THE BACKGROUND\n    radar_thread = Thread(radar_sweep_task)\n    \n    while True:\n        # Get joystick inputs (Negative due to orientation purposes)\n        forward_axis = -controller_1.axis3.position()\n        strafe_axis = -controller_1.axis4.position()\n        turn_axis = -controller_1.axis1.position()\n        \n        # Deadbands so the robot doesn't drift\n        if abs(forward_axis) < 5: forward_axis = 0\n        if abs(strafe_axis) < 5: strafe_axis = 0\n        if abs(turn_axis) < 5: turn_axis = 0\n        \n        # Drive the robot\n        drive_holonomic(forward_axis, strafe_axis, turn_axis)\n        \n        # Calibration mode trigger\n        if controller_1.buttonA.pressing():\n            drive_holonomic(0, 0, 0)\n            radar_thread.stop() # Stop the radar when calibrating\n            motorVision.spin_to_position(0,DEGREES,wait=True)\n            motorVision.stop()\n            calibrate_sensors()\n            \n        wait(20, MSEC)\n\n# Start the code\nmain()","textLanguage":"python","robotConfig":[{"port":[3],"name":"motorVision","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[5],"name":"opLeft","customName":true,"deviceType":"Optical","deviceClass":"optical","setting":{},"triportSourcePort":22},{"port":[6],"name":"opRight","customName":true,"deviceType":"Optical","deviceClass":"optical","setting":{},"triportSourcePort":22},{"port":[4],"name":"distanceLeft","customName":true,"deviceType":"Distance","deviceClass":"distance","setting":{},"triportSourcePort":22},{"port":[7],"name":"opticalDown","customName":true,"deviceType":"Optical","deviceClass":"optical","setting":{},"triportSourcePort":22},{"port":[16],"name":"back_right","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[17],"name":"front_right","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[14],"name":"front_left","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"true","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[15],"name":"back_left","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"true","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22},{"port":[],"name":"controller_1","customName":false,"deviceType":"Controller","deviceClass":"controller","setting":{"left":"","leftDir":"false","right":"","rightDir":"false","upDown":"","upDownDir":"false","xB":"","xBDir":"false","drive":"none","id":"primary"},"triportSourcePort":22}],"slot":0,"platform":"V5","sdkVersion":"20240802.15.00.00","appVersion":"4.65.0","fileFormat":"2.0.0","targetBrainGen":"First","v5Sounds":[{"name":"game over","url":"static/sounds/mixkit-arcade-retro-game-over-213.wav"}],"v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null}}